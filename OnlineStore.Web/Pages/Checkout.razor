@page "/checkout"
@using OnlineStore.Domain.Entities
@using FluentValidation.AspNetCore
@inject FluentValidation.IValidator<Order> Validator

<PageTitle>Оформление заказа</PageTitle>

<div class="container py-4">
    <h2 class="mb-4">Оформление заказа</h2>

    @if (_isSuccess)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <strong>Заказ успешно оформлен!</strong> Мы свяжемся с вами в ближайшее время.
            <button type="button" class="btn-close" @onclick="@(() => _isSuccess = false)" aria-label="Close"></button>
        </div>
    }

    <EditForm Model="@_order" OnSubmit="@HandleSubmit">
        <FluentValidationValidator />

        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Имя *</label>
                <InputText @bind-Value="_order.CustomerName" class="form-control" placeholder="Иван Иванов" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Email *</label>
                <InputText @bind-Value="_order.Email" class="form-control" type="email" placeholder="ivan@example.com" />
            </div>
            <div class="col-md-6">
                <label class="form-label">Телефон *</label>
                <InputText @bind-Value="_order.Phone" class="form-control" placeholder="+79991234567" />
            </div>
            <div class="col-12">
                <label class="form-label">Адрес доставки *</label>
                <InputText @bind-Value="_order.Address" class="form-control" placeholder="г. Москва, ул. Примерная, д. 1" />
            </div>
        </div>

        <div class="mt-4">
            <button type="submit" class="btn btn-primary btn-lg">Подтвердить заказ</button>
            <a href="/" class="btn btn-outline-secondary btn-lg ms-2">Вернуться в каталог</a>
        </div>
    </EditForm>
</div>

@code {
    private Order _order = new()
    {
        CustomerName = string.Empty,
        Email = string.Empty,
        Phone = string.Empty,
        Address = string.Empty
    };
    private bool _isSuccess = false;

    private async Task HandleSubmit()
    {
        var validationResult = await Validator.ValidateAsync(_order);
        if (!validationResult.IsValid) return;

        _order.TotalPrice = 0m;
        _order.CreatedAt = DateTime.UtcNow;

        _isSuccess = true;
        _order = new()
        {
            CustomerName = string.Empty,
            Email = string.Empty,
            Phone = string.Empty,
            Address = string.Empty
        };
        StateHasChanged();
    }
}
